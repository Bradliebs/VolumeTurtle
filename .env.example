DATABASE_URL=postgresql://postgres:postgres@localhost:5433/volume_turtle

# ── Core Trading Parameters ──
VOLUME_TURTLE_BALANCE=560
MAX_POSITIONS=5
RISK_PER_TRADE_PCT=2
VOLUME_SPIKE_MULTIPLIER=2
RANGE_POSITION_THRESHOLD=0.75
ATR_PERIOD=20
TRAILING_STOP_DAYS=10
HARD_STOP_ATR_MULTIPLE=1.5

# ATR trailing stop multiplier
TRAIL_ATR_MULTIPLE=1.5

# VIX position sizing multipliers
VIX_NORMAL_SIZE_MULT=1.0
VIX_ELEVATED_SIZE_MULT=0.75
VIX_PANIC_SIZE_MULT=0.0

# ── Equity Curve Circuit Breaker ──
CAUTION_DRAWDOWN_PCT=10
PAUSE_DRAWDOWN_PCT=20

# ── Composite Score Weights (must sum to ~1.0) ──
SCORE_WEIGHT_REGIME=0.40
SCORE_WEIGHT_TREND=0.30
SCORE_WEIGHT_VOLUME=0.20
SCORE_WEIGHT_LIQUIDITY=0.10

# ── Data Fetch Tuning ──
QUOTE_BATCH_SIZE=10
QUOTE_BATCH_DELAY_MS=500
QUOTE_LOOKBACK_DAYS=60

# ── Authentication ──
SCHEDULED_SCAN_TOKEN=choose-a-long-random-string-here
DASHBOARD_TOKEN=3006disbake

# ── Trading 212 (optional) ──
# T212_API_KEY=your-api-key
# T212_API_SECRET=your-api-secret
# T212_ENVIRONMENT=demo
# T212_ACCOUNT_TYPE=isa

# ── Momentum engine ──
MOMENTUM_ENABLED=true

# ── Scan schedule (UTC hours) ──
SCAN_START_HOUR=14
SCAN_END_HOUR=20

# ── Execution window ──
AUTO_EXECUTION_WINDOW_MINS=15
AUTO_EXECUTION_MAX_PER_DAY=2

# ── Runner mandate ──
RUNNER_PROFIT_THRESHOLD=0.30
RUNNER_LOOKBACK_DAYS=20

# ── AI / Claude ──
ANTHROPIC_API_KEY=your-key-here
AGENT_ENABLED=false
TRADECORE_BASE_URL=http://localhost:3000

# ── Portfolio heat cap (optional, agent-recommended) ──
# HEAT_CAP_PCT=0.08

# ── Gap guardrail thresholds ──
GAP_DOWN_THRESHOLD=0.03
GAP_UP_RESIZE_THRESHOLD=0.05

# ── Data validation (optional, for cross-validation) ──
# ALPHA_VANTAGE_KEY=
# FINNHUB_API_KEY=

# ── Logging ──
# LOG_LEVEL=info
