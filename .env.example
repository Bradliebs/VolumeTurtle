DATABASE_URL=postgresql://postgres:postgres@localhost:5433/volume_turtle
VOLUME_TURTLE_BALANCE=560
MAX_POSITIONS=5
RISK_PER_TRADE_PCT=2
VOLUME_SPIKE_MULTIPLIER=2
RANGE_POSITION_THRESHOLD=0.75
ATR_PERIOD=20
TRAILING_STOP_DAYS=10
HARD_STOP_ATR_MULTIPLE=2
SCHEDULED_SCAN_TOKEN=choose-a-long-random-string-here
SCORE_WEIGHT_REGIME=0.40
SCORE_WEIGHT_TREND=0.30
SCORE_WEIGHT_VOLUME=0.20
SCORE_WEIGHT_LIQUIDITY=0.10
