DATABASE_URL=postgresql://postgres:postgres@localhost:5433/volume_turtle

# ── Core Trading Parameters ──
VOLUME_TURTLE_BALANCE=560
MAX_POSITIONS=5
RISK_PER_TRADE_PCT=2
VOLUME_SPIKE_MULTIPLIER=2
RANGE_POSITION_THRESHOLD=0.75
ATR_PERIOD=20
TRAILING_STOP_DAYS=10
HARD_STOP_ATR_MULTIPLE=1.5
VIX_NORMAL_SIZE_MULT=1.0
VIX_ELEVATED_SIZE_MULT=0.75

# ── Equity Curve Circuit Breaker ──
CAUTION_DRAWDOWN_PCT=10
PAUSE_DRAWDOWN_PCT=20

# ── Composite Score Weights (must sum to ~1.0) ──
SCORE_WEIGHT_REGIME=0.40
SCORE_WEIGHT_TREND=0.30
SCORE_WEIGHT_VOLUME=0.20
SCORE_WEIGHT_LIQUIDITY=0.10

# ── Data Fetch Tuning ──
QUOTE_BATCH_SIZE=10
QUOTE_BATCH_DELAY_MS=500
QUOTE_LOOKBACK_DAYS=60

# ── Authentication ──
# Both tokens below are auto-generated by INSTALL.bat on first run.
# SCHEDULED_SCAN_TOKEN — used by Task Scheduler to authenticate scans (do not change unless you also update the system env var)
SCHEDULED_SCAN_TOKEN=choose-a-long-random-string-here
# DASHBOARD_TOKEN — what you type into the login screen (change to whatever you like after install)
DASHBOARD_TOKEN=change-me-or-auto-generated

# ── Trading 212 (optional) ──
# T212_API_KEY=your-api-key
# T212_API_SECRET=your-api-secret
# T212_ENVIRONMENT=demo
# T212_ACCOUNT_TYPE=isa

# ── Logging ──
# LOG_LEVEL=info
