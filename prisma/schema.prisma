// VolumeTurtle — Prisma Schema (independent from HybridTurtle)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A ticker in the scan universe
model Ticker {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String?
  sector    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes  DailyQuote[]

  @@index([symbol])
}

/// OHLCV daily bar from Yahoo Finance
model DailyQuote {
  id        Int      @id @default(autoincrement())
  tickerId  Int
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  adjClose  Float
  volume    BigInt

  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, date])
  @@index([date])
}

/// Nightly scan run metadata
model ScanRun {
  id          Int      @id @default(autoincrement())
  startedAt   DateTime @default(now())
  completedAt DateTime?
  tickersScanned Int   @default(0)
  signalsFound   Int   @default(0)
  status      String   @default("RUNNING") // RUNNING | COMPLETED | FAILED
  error       String?
  trigger     String   @default("MANUAL") // MANUAL | SCHEDULED
  market      String   @default("ALL")    // ALL | LSE | US | EU
  durationMs  Int?                        // scan duration in milliseconds
  marketRegime String?                    // BULLISH | BEARISH
  vixLevel     String?
  vixValue     Float?
  qqqVs200MA   Float?                     // % above/below 200MA
  regimeScore      Int?
  regimeAssessment String?
  scanType         String   @default("volume") // "volume" | "momentum" | "both"
  validationBlocked  Int    @default(0)
  validationWarnings Int    @default(0)
  crossValidated     Int    @default(0)
  // Market breadth metrics
  breadthScore        Float?
  breadthSignal       String?   // STRONG | NEUTRAL | WEAK | DETERIORATING
  breadthTrend        String?   // IMPROVING | STABLE | DECLINING
  above50MAPct        Float?    // % above 50d MA
  above200MAPct       Float?    // % above 200d MA
  newHighLowRatio     Float?    // new highs vs lows ratio
  advanceDeclinePct   Float?    // % advancing on the day
}

model SectorScanResult {
  id           Int      @id @default(autoincrement())
  runAt        DateTime @default(now())
  sector       String
  score        Float
  R5           Float
  R20          Float
  volRatio     Float
  R5Rank       Float
  R20Rank      Float
  volRank      Float
  tickerCount  Int      @default(0)
  hotCount     Int      @default(0)
  ma5AboveMa20 Boolean  @default(false)
  scanRunId    Int?
}

model MomentumSignal {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  ticker         String
  sector         String
  chg1d          Float
  volRatio       Float
  R5             Float
  R20            Float
  price          Float
  sma20          Float
  atr            Float
  stopPrice      Float
  compositeScore Float
  grade          String   // "A" | "B" | "C" | "D"
  regimeScore    Int
  tickerTrend    String
  sectorScore    Float
  sectorRank     Int
  status         String   @default("active") // "active" | "near-miss" | "expired"
  scanRunId      Int?
  dataWarnings   String?  // JSON array of validation warning strings, null if clean

  @@unique([ticker, scanRunId])
}

model WatchlistItem {
  id      Int      @id @default(autoincrement())
  ticker  String   @unique
  sector  String
  addedAt DateTime @default(now())
  notes   String?
  source  String   @default("manual") // "manual" | "near-miss" | "volume" | "momentum"
}

model Alert {
  id           Int      @id @default(autoincrement())
  type         String
  ticker       String
  message      String
  severity     String   @default("info")
  price        Float?
  stopPrice    Float?
  signalSource String?  // "volume" | "momentum"
  acknowledged Boolean  @default(false)
  sentTelegram Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([acknowledged])
  @@index([ticker])
}

model TelegramSettings {
  id        Int      @id @default(autoincrement())
  botToken  String
  chatId    String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// A trade opened (and possibly closed) by VolumeTurtle
model Trade {
  id            String    @id @default(cuid())
  ticker        String
  entryDate     DateTime
  entryPrice    Float
  shares        Float
  hardStop      Float
  trailingStop  Float
  exitDate      DateTime?
  exitPrice     Float?
  exitReason    String?   // ExitReason: "HARD_STOP" | "TRAILING_STOP" | "MANUAL" | "T212_STOP"
  rMultiple     Float?    // (exitPrice - entryPrice) / riskPerShare
  status        String    // "OPEN" | "CLOSED"
  volumeRatio   Float     // volume spike ratio at entry
  rangePosition Float     // price range position at entry
  atr20         Float     // ATR at entry
  signalSource  String    @default("volume") // "volume" | "momentum" | "manual"
  signalScore   Float?    // composite score at time of entry
  signalGrade   String?   // "A" | "B" | "C" | "D"
  sector        String?   // sector classification for concentration tracking
  timingScore            Float?
  closeStrength          Float?
  volumeExpansion        Float?
  rangeStability         Float?
  flowFlag               Boolean?
  flowType               String?
  timingGatePass         Boolean?
  positionSizeMultiplier Float?
  hardStopPrice     Float?
  trailingStopPrice Float?
  peakClosePrice    Float?
  stopSource        String?
  importedFromT212  Boolean   @default(false)
  importedAt        DateTime?
  manualEntry       Boolean   @default(false)
  lastSyncedAt      DateTime?
  isRunner          Boolean   @default(false)
  runnerActivatedAt DateTime? // when 30% threshold crossed
  runnerPeakProfit  Float?    // highest % profit seen as runner
  runnerExitProfit  Float?    // % profit at exit (filled on close)
  runnerCaptureRate Float?    // runnerExitProfit / runnerPeakProfit
  // Stop push tracking (two-layer system)
  stopPushedAt      DateTime? // when stop was last successfully pushed to T212
  stopPushAttempts  Int       @default(0) // total push attempts (Layer 1 + Layer 2)
  stopPushError     String?   // last push error message (null = success)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stopHistory   StopHistory[]
  ratchetEvents CruiseControlRatchetEvent[]

  @@index([ticker])
  @@index([status])
}

/// Stop level history for a trade
model StopHistory {
  id            String    @id @default(cuid())
  tradeId       String
  trade         Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  date          DateTime
  stopLevel     Float
  stopType      String    // "HARD" | "TRAILING"
  changed       Boolean   // true if stop moved up vs previous day
  changeAmount  Float?    // positive number, only set if changed = true
  actioned      Boolean   @default(false)
  actionedAt    DateTime?
  note          String?   // optional note explaining stop change
  createdAt     DateTime  @default(now())

  @@index([tradeId])
}

/// Result of a nightly scan for a single ticker
model ScanResult {
  id            String   @id @default(cuid())
  scanDate      DateTime
  ticker        String
  signalFired   Boolean
  volumeRatio   Float?
  rangePosition Float?
  atr20          Float?
  compositeScore Float?   // 0.00–1.00 composite signal quality
  compositeGrade String?  // "A" | "B" | "C" | "D"
  actionTaken    String?  // "ENTERED" | "SIGNAL_FIRED" | "SKIPPED_MAX_POSITIONS" | "SKIPPED_EQUITY_PAUSE" | "NO_SIGNAL"
  // Signal detail (populated only when signalFired = true)
  suggestedEntry Float?
  hardStop        Float?
  riskPerShare    Float?
  shares          Float?
  totalExposure   Float?
  dollarRisk      Float?
  // Composite sub-scores
  regimeScore     Float?
  trendScore      Float?
  volumeCompScore Float?  // named to avoid clash with volumeRatio
  liquidityScore  Float?
  createdAt      DateTime @default(now())

  @@unique([ticker, scanDate])
  @@index([scanDate])
  @@index([ticker])
}

/// Daily account balance snapshot
model AccountSnapshot {
  id         String   @id @default(cuid())
  date       DateTime
  balance    Float
  openTrades Int
  createdAt  DateTime @default(now())

  @@index([date])
}

/// Key-value settings store
model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

/// Trading 212 connection configuration
model T212Connection {
  id              String    @id @default(cuid())
  environment     String    // "demo" | "live"
  apiKey          String    // env var reference e.g. "ENV:T212_API_KEY"
  accountType     String    // "invest" | "isa" | "both"
  connected       Boolean   @default(false)
  lastSyncAt      DateTime?
  lastSyncStatus  String?   // "success" | "error"
  lastSyncError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Unified app settings (DB-configurable, falls back to env vars)
model AppSettings {
  id                    Int      @id @default(autoincrement())
  momentumEnabled       Boolean  @default(true)
  breakoutMinChg        Float    @default(0.10)
  breakoutMinVol        Float    @default(3.0)
  scoreWeightRegime     Float    @default(0.35)
  scoreWeightBreakout   Float    @default(0.30)
  scoreWeightSector     Float    @default(0.25)
  scoreWeightLiquidity  Float    @default(0.10)
  runnerEnabled         Boolean  @default(true)
  runnerProfitThreshold Float    @default(0.30)
  runnerLookbackDays    Int      @default(20)
  // Auto-execution settings
  autoExecutionEnabled    Boolean @default(false)
  autoExecutionMinGrade   String  @default("B")   // "A" or "B"
  autoExecutionWindowMins Int     @default(15)     // cancellation window (5–60)
  autoExecutionMaxPerDay  Int     @default(2)      // max orders per calendar day
  autoExecutionStartHour  Int     @default(14)     // UTC start hour
  autoExecutionEndHour    Int     @default(20)     // UTC end hour
  maxPositionsPerSector   Int     @default(2)      // max open positions in one sector
  gapDownThreshold       Float   @default(0.03)   // cancel if open is X% below signal close
  gapUpResizeThreshold   Float   @default(0.05)   // resize if open is X% above signal close
  vixNormalSizeMult      Float   @default(1.00)   // VIX < 25: full size
  vixElevatedSizeMult    Float   @default(0.75)   // VIX 25-35: 75% size
  earlyPauseToCautionPct Float   @default(22.0)   // early PAUSE→CAUTION when drawdown < this % (above 20% PAUSE threshold)
  earlyCautionToNormalPct Float  @default(12.0)    // early CAUTION→NORMAL when drawdown < this % (above 10% CAUTION threshold)
  // Cruise control polling cadence
  cruisePollIntervalMins      Int @default(60)    // base interval (off-peak hours)
  cruisePollFastIntervalMins  Int @default(30)    // fast interval during high-action window
  cruisePollFastStartUtcHour  Int @default(8)     // fast window start (UTC)
  cruisePollFastEndUtcHour    Int @default(16)    // fast window end (UTC, exclusive)
  updatedAt             DateTime @updatedAt
}

// ── Cruise Control ──────────────────────────────────────────────────────────

/// Global on/off state for the cruise control daemon
model CruiseControlState {
  id            Int       @id @default(autoincrement())
  isEnabled     Boolean   @default(false)
  enabledAt     DateTime?
  disabledAt    DateTime?
  lastPollAt    DateTime?
  nextPollAt    DateTime?
  pollCount     Int       @default(0)
  totalRatchets Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Record of each individual stop ratchet applied by cruise control
model CruiseControlRatchetEvent {
  id            Int      @id @default(autoincrement())
  positionType  String   // 'momentum' | 'pead' | 'pairs-long'
  positionId    String
  ticker        String
  pollTimestamp DateTime
  oldStop       Float
  newStop       Float
  ratchetPct    Float
  currentPrice  Float
  profitPct     Float
  atrUsed       Float
  t212Updated   Boolean
  t212Response  String?
  createdAt     DateTime @default(now())

  trade Trade @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([ticker])
  @@index([pollTimestamp])
  @@index([positionType])
}

// ── Auto-Execution ──────────────────────────────────────────────────────────

/// Pending auto-execution order awaiting cancellation window
model PendingOrder {
  id              Int       @id @default(autoincrement())
  ticker          String
  sector          String
  signalSource    String    // "volume" | "momentum"
  signalGrade     String    // "A" | "B"
  compositeScore  Float
  suggestedShares Float
  suggestedEntry  Float     // price at signal time
  suggestedStop   Float     // ATR stop
  dollarRisk      Float     // £ at risk
  status          String    @default("pending")
  // "pending" | "cancelled" | "executed" | "failed" | "expired"
  cancelDeadline  DateTime  // createdAt + cancellation window
  cancelledAt     DateTime?
  cancelReason    String?
  executedAt      DateTime?
  t212OrderId     String?
  actualShares    Float?
  actualPrice     Float?
  failureReason   String?
  isRunner        Boolean   @default(false)
  createdAt       DateTime  @default(now())

  executionLogs ExecutionLog[]

  @@index([status])
  @@index([cancelDeadline])
  @@index([ticker])
}

/// Full audit trail for every auto-execution event
model ExecutionLog {
  id        Int      @id @default(autoincrement())
  orderId   Int
  event     String
  // "CREATED" | "PRE_FLIGHT_PASS" | "PRE_FLIGHT_FAIL"
  // | "CANCELLED" | "SUBMITTED" | "CONFIRMED" | "FAILED"
  // | "STOP_PUSHED" | "STOP_PUSH_FAILED" | "EXPIRED"
  detail    String
  createdAt DateTime @default(now())

  order PendingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

/// Alerts generated by cruise control requiring human attention
model CruiseControlAlert {
  id             Int       @id @default(autoincrement())
  alertType      String    // 'critical' | 'warning' | 'info'
  message        String
  context        Json?
  delivered      Boolean   @default(false)
  deliveredAt    DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([alertType])
  @@index([createdAt])
}

/// Log of each poll cycle run by cruise control
model CruiseControlPollLog {
  id               Int       @id @default(autoincrement())
  pollStartedAt    DateTime
  pollCompletedAt  DateTime?
  durationMs       Int?
  positionsChecked Int       @default(0)
  stopsRatcheted   Int       @default(0)
  stopsUnchanged   Int       @default(0)
  retryFailures    Int       @default(0)
  t212Unavailable  Boolean   @default(false)
  error            String?
  createdAt        DateTime  @default(now())

  @@index([pollStartedAt])
}

// ── Sessions ────────────────────────────────────────────────────────────────

/// Dashboard login session (replaces in-memory token storage)
model Session {
  id        String   @id
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ── Retry Queue ─────────────────────────────────────────────────────────────

/// Persisted retry queue for failed T212 stop pushes (survives daemon restarts)
model RetryQueue {
  id          Int      @id @default(autoincrement())
  ticker      String
  stopPrice   Float
  quantity    Float
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  nextRetryAt DateTime

  @@index([nextRetryAt])
  @@index([ticker])
}

// ─────────────────────────────────────────────────────────────────────────────
// Backtester models — see src/lib/backtest/
// ─────────────────────────────────────────────────────────────────────────────

/// One backtest execution. Stores parameters + summary metrics.
model BacktestRun {
  id              Int       @id @default(autoincrement())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  label           String?   // human-friendly description
  startDate       DateTime  // inclusive backtest window start
  endDate         DateTime  // inclusive backtest window end
  initialCapital  Float
  // Strategy params snapshot (so results are reproducible)
  engine          String    @default("volume") // "volume" | "momentum"
  volumeMultiplier Float?
  rangePosThreshold Float?
  hardStopAtrMult  Float?
  trailingStopDays Int?
  riskPctPerTrade  Float?
  // Cost model snapshot
  commissionPerTrade Float
  slippageBps      Float
  spreadBps        Float
  // Tier-2 risk control snapshot
  convictionMultA  Float?
  convictionMultB  Float?
  convictionMultC  Float?
  convictionMultD  Float?
  portfolioHeatCapPct Float?
  maxPositionsPerSector Int?
  // Result metrics (filled at completion)
  trades           Int      @default(0)
  wins             Int      @default(0)
  losses           Int      @default(0)
  winRate          Float?
  profitFactor     Float?
  expectancyR      Float?   // average R-multiple per trade
  totalReturnPct   Float?
  cagrPct          Float?
  sharpe           Float?
  sortino          Float?
  maxDrawdownPct   Float?
  maxDrawdownDays  Int?
  finalEquity      Float?
  // Tier-2 diagnostics — count of would-be entries blocked by gates.
  blockedByHeatCap     Int?
  blockedBySectorCap   Int?
  // Actual covered window (may be narrower than [startDate, endDate] when
  // historical quote coverage is sparse — surfaced as a UI warning).
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  actualYears      Float?
  status           String   @default("RUNNING") // RUNNING | COMPLETED | FAILED
  error            String?
  // For walk-forward — links train/validate/test windows
  parentRunId      Int?
  fold             String?  // "train" | "validate" | "test" | null
  notes            String?

  backtestTrades   BacktestTrade[]

  @@index([startedAt])
  @@index([parentRunId])
}

/// A simulated trade in a backtest. Mirrors live Trade fields where relevant.
model BacktestTrade {
  id              Int       @id @default(autoincrement())
  runId           Int
  run             BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ticker          String
  entryDate       DateTime
  entryPrice      Float    // includes slippage
  rawEntryPrice   Float    // close before slippage
  shares          Float
  hardStop        Float
  exitDate        DateTime?
  exitPrice       Float?   // includes slippage
  rawExitPrice    Float?
  exitReason      String?  // "HARD_STOP" | "TRAILING_STOP" | "END_OF_BACKTEST"
  rMultiple       Float?
  pnl             Float?   // gross P&L in account currency
  pnlNet          Float?   // after commission + slippage
  costs           Float?   // commission + spread + slippage cost
  barsHeld        Int?
  signalGrade     String?
  signalScore     Float?
  volumeRatio     Float?
  atr20           Float?

  @@index([runId])
  @@index([ticker])
}

/// Point-in-time snapshot of the trading universe.
/// Eliminates survivorship bias in backtests by replaying signals only
/// against tickers that were actually in the universe on that historical date.
model UniverseSnapshot {
  id          Int      @id @default(autoincrement())
  snapshotDate DateTime
  ticker      String
  sector      String?
  source      String   @default("manual") // "manual" | "csv" | "auto"

  @@unique([snapshotDate, ticker])
  @@index([snapshotDate])
}
// ── Agent models ──────────────────────────────────────────────────

model AiSettings {
  id              Int      @id @default(1)
  enabled         Boolean  @default(false)
  anthropicApiKey String?
  model           String   @default("claude-sonnet-4-20250514")
  maxTokens       Int      @default(2048)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentHaltFlag {
  id        Int       @id @default(1)
  halted    Boolean   @default(false)
  reason    String?
  setAt     DateTime?
  setBy     String?
  updatedAt DateTime  @updatedAt
}

model AgentDecisionLog {
  id             Int      @id @default(autoincrement())
  cycleId        String
  cycleStartedAt DateTime
  contextJson    String   @db.Text
  reasoning      String   @db.Text
  actionsJson    String   @db.Text
  outcomeJson    String   @db.Text
  telegramSent   Boolean  @default(false)
  durationMs     Int
  errorMessage   String?
  createdAt      DateTime @default(now())
}