// VolumeTurtle — Prisma Schema (independent from HybridTurtle)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A ticker in the scan universe
model Ticker {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String?
  sector    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes  DailyQuote[]

  @@index([symbol])
}

/// OHLCV daily bar from Yahoo Finance
model DailyQuote {
  id        Int      @id @default(autoincrement())
  tickerId  Int
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  adjClose  Float
  volume    BigInt

  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, date])
  @@index([date])
}

/// Nightly scan run metadata
model ScanRun {
  id          Int      @id @default(autoincrement())
  startedAt   DateTime @default(now())
  completedAt DateTime?
  tickersScanned Int   @default(0)
  signalsFound   Int   @default(0)
  status      String   @default("RUNNING") // RUNNING | COMPLETED | FAILED
  error       String?
  trigger     String   @default("MANUAL") // MANUAL | SCHEDULED
  market      String   @default("ALL")    // ALL | LSE | US | EU
  durationMs  Int?                        // scan duration in milliseconds
  marketRegime String?                    // BULLISH | BEARISH
  vixLevel     String?
  vixValue     Float?
  qqqVs200MA   Float?                     // % above/below 200MA
  regimeScore      Int?
  regimeAssessment String?
  scanType         String   @default("volume") // "volume" | "momentum" | "both"
  validationBlocked  Int    @default(0)
  validationWarnings Int    @default(0)
  crossValidated     Int    @default(0)
}

model SectorScanResult {
  id           Int      @id @default(autoincrement())
  runAt        DateTime @default(now())
  sector       String
  score        Float
  R5           Float
  R20          Float
  volRatio     Float
  R5Rank       Float
  R20Rank      Float
  volRank      Float
  tickerCount  Int      @default(0)
  hotCount     Int      @default(0)
  ma5AboveMa20 Boolean  @default(false)
  scanRunId    Int?
}

model MomentumSignal {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  ticker         String
  sector         String
  chg1d          Float
  volRatio       Float
  R5             Float
  R20            Float
  price          Float
  sma20          Float
  atr            Float
  stopPrice      Float
  compositeScore Float
  grade          String   // "A" | "B" | "C" | "D"
  regimeScore    Int
  tickerTrend    String
  sectorScore    Float
  sectorRank     Int
  status         String   @default("active") // "active" | "near-miss" | "expired"
  scanRunId      Int?
  dataWarnings   String?  // JSON array of validation warning strings, null if clean

  @@unique([ticker, scanRunId])
}

model WatchlistItem {
  id      Int      @id @default(autoincrement())
  ticker  String   @unique
  sector  String
  addedAt DateTime @default(now())
  notes   String?
  source  String   @default("manual") // "manual" | "near-miss" | "volume" | "momentum"
}

model Alert {
  id           Int      @id @default(autoincrement())
  type         String
  ticker       String
  message      String
  severity     String   @default("info")
  price        Float?
  stopPrice    Float?
  signalSource String?  // "volume" | "momentum"
  acknowledged Boolean  @default(false)
  sentTelegram Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model TelegramSettings {
  id        Int      @id @default(autoincrement())
  botToken  String
  chatId    String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// A trade opened (and possibly closed) by VolumeTurtle
model Trade {
  id            String    @id @default(cuid())
  ticker        String
  entryDate     DateTime
  entryPrice    Float
  shares        Float
  hardStop      Float
  trailingStop  Float
  exitDate      DateTime?
  exitPrice     Float?
  exitReason    String?   // ExitReason: "HARD_STOP" | "TRAILING_STOP" | "MANUAL" | "T212_STOP"
  rMultiple     Float?    // (exitPrice - entryPrice) / riskPerShare
  status        String    // "OPEN" | "CLOSED"
  volumeRatio   Float     // volume spike ratio at entry
  rangePosition Float     // price range position at entry
  atr20         Float     // ATR at entry
  signalSource  String    @default("volume") // "volume" | "momentum" | "manual"
  signalScore   Float?    // composite score at time of entry
  signalGrade   String?   // "A" | "B" | "C" | "D"
  timingScore            Float?
  closeStrength          Float?
  volumeExpansion        Float?
  rangeStability         Float?
  flowFlag               Boolean?
  flowType               String?
  timingGatePass         Boolean?
  positionSizeMultiplier Float?
  hardStopPrice     Float?
  trailingStopPrice Float?
  peakClosePrice    Float?
  stopSource        String?
  importedFromT212  Boolean   @default(false)
  importedAt        DateTime?
  manualEntry       Boolean   @default(false)
  lastSyncedAt      DateTime?
  isRunner          Boolean   @default(false)
  runnerActivatedAt DateTime? // when 30% threshold crossed
  runnerPeakProfit  Float?    // highest % profit seen as runner
  runnerExitProfit  Float?    // % profit at exit (filled on close)
  runnerCaptureRate Float?    // runnerExitProfit / runnerPeakProfit
  // Stop push tracking (two-layer system)
  stopPushedAt      DateTime? // when stop was last successfully pushed to T212
  stopPushAttempts  Int       @default(0) // total push attempts (Layer 1 + Layer 2)
  stopPushError     String?   // last push error message (null = success)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stopHistory   StopHistory[]

  @@index([ticker])
  @@index([status])
}

/// Stop level history for a trade
model StopHistory {
  id            String    @id @default(cuid())
  tradeId       String
  trade         Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  date          DateTime
  stopLevel     Float
  stopType      String    // "HARD" | "TRAILING"
  changed       Boolean   // true if stop moved up vs previous day
  changeAmount  Float?    // positive number, only set if changed = true
  actioned      Boolean   @default(false)
  actionedAt    DateTime?
  note          String?   // optional note explaining stop change
  createdAt     DateTime  @default(now())

  @@index([tradeId])
}

/// Result of a nightly scan for a single ticker
model ScanResult {
  id            String   @id @default(cuid())
  scanDate      DateTime
  ticker        String
  signalFired   Boolean
  volumeRatio   Float?
  rangePosition Float?
  atr20          Float?
  compositeScore Float?   // 0.00–1.00 composite signal quality
  compositeGrade String?  // "A" | "B" | "C" | "D"
  actionTaken    String?  // "ENTERED" | "SIGNAL_FIRED" | "SKIPPED_MAX_POSITIONS" | "SKIPPED_EQUITY_PAUSE" | "NO_SIGNAL"
  // Signal detail (populated only when signalFired = true)
  suggestedEntry Float?
  hardStop        Float?
  riskPerShare    Float?
  shares          Float?
  totalExposure   Float?
  dollarRisk      Float?
  // Composite sub-scores
  regimeScore     Float?
  trendScore      Float?
  volumeCompScore Float?  // named to avoid clash with volumeRatio
  liquidityScore  Float?
  createdAt      DateTime @default(now())

  @@unique([ticker, scanDate])
  @@index([scanDate])
  @@index([ticker])
}

/// Daily account balance snapshot
model AccountSnapshot {
  id         String   @id @default(cuid())
  date       DateTime
  balance    Float
  openTrades Int
  createdAt  DateTime @default(now())

  @@index([date])
}

/// Key-value settings store
model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

/// Trading 212 connection configuration
model T212Connection {
  id              String    @id @default(cuid())
  environment     String    // "demo" | "live"
  apiKey          String    // env var reference e.g. "ENV:T212_API_KEY"
  accountType     String    // "invest" | "isa" | "both"
  connected       Boolean   @default(false)
  lastSyncAt      DateTime?
  lastSyncStatus  String?   // "success" | "error"
  lastSyncError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Unified app settings (DB-configurable, falls back to env vars)
model AppSettings {
  id                    Int      @id @default(autoincrement())
  momentumEnabled       Boolean  @default(true)
  breakoutMinChg        Float    @default(0.10)
  breakoutMinVol        Float    @default(3.0)
  scoreWeightRegime     Float    @default(0.35)
  scoreWeightBreakout   Float    @default(0.30)
  scoreWeightSector     Float    @default(0.25)
  scoreWeightLiquidity  Float    @default(0.10)
  runnerEnabled         Boolean  @default(true)
  runnerProfitThreshold Float    @default(0.30)
  runnerLookbackDays    Int      @default(20)
  // Auto-execution settings
  autoExecutionEnabled    Boolean @default(false)
  autoExecutionMinGrade   String  @default("B")   // "A" or "B"
  autoExecutionWindowMins Int     @default(15)     // cancellation window (5–60)
  autoExecutionMaxPerDay  Int     @default(2)      // max orders per calendar day
  autoExecutionStartHour  Int     @default(14)     // UTC start hour
  autoExecutionEndHour    Int     @default(20)     // UTC end hour
  updatedAt             DateTime @updatedAt
}

// ── Cruise Control ──────────────────────────────────────────────────────────

/// Global on/off state for the cruise control daemon
model CruiseControlState {
  id            Int       @id @default(autoincrement())
  isEnabled     Boolean   @default(false)
  enabledAt     DateTime?
  disabledAt    DateTime?
  lastPollAt    DateTime?
  nextPollAt    DateTime?
  pollCount     Int       @default(0)
  totalRatchets Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Record of each individual stop ratchet applied by cruise control
model CruiseControlRatchetEvent {
  id            Int      @id @default(autoincrement())
  positionType  String   // 'momentum' | 'pead' | 'pairs-long'
  positionId    String
  ticker        String
  pollTimestamp DateTime
  oldStop       Float
  newStop       Float
  ratchetPct    Float
  currentPrice  Float
  profitPct     Float
  atrUsed       Float
  t212Updated   Boolean
  t212Response  String?
  createdAt     DateTime @default(now())

  @@index([ticker])
  @@index([pollTimestamp])
  @@index([positionType])
}

// ── Auto-Execution ──────────────────────────────────────────────────────────

/// Pending auto-execution order awaiting cancellation window
model PendingOrder {
  id              Int       @id @default(autoincrement())
  ticker          String
  sector          String
  signalSource    String    // "volume" | "momentum"
  signalGrade     String    // "A" | "B"
  compositeScore  Float
  suggestedShares Float
  suggestedEntry  Float     // price at signal time
  suggestedStop   Float     // ATR stop
  dollarRisk      Float     // £ at risk
  status          String    @default("pending")
  // "pending" | "cancelled" | "executed" | "failed" | "expired"
  cancelDeadline  DateTime  // createdAt + cancellation window
  cancelledAt     DateTime?
  cancelReason    String?
  executedAt      DateTime?
  t212OrderId     String?
  actualShares    Float?
  actualPrice     Float?
  failureReason   String?
  isRunner        Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([cancelDeadline])
  @@index([ticker])
}

/// Full audit trail for every auto-execution event
model ExecutionLog {
  id        Int      @id @default(autoincrement())
  orderId   Int
  event     String
  // "CREATED" | "PRE_FLIGHT_PASS" | "PRE_FLIGHT_FAIL"
  // | "CANCELLED" | "SUBMITTED" | "CONFIRMED" | "FAILED"
  // | "STOP_PUSHED" | "STOP_PUSH_FAILED" | "EXPIRED"
  detail    String
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

/// Alerts generated by cruise control requiring human attention
model CruiseControlAlert {
  id             Int       @id @default(autoincrement())
  alertType      String    // 'critical' | 'warning' | 'info'
  message        String
  context        Json?
  delivered      Boolean   @default(false)
  deliveredAt    DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([alertType])
  @@index([createdAt])
}

/// Log of each poll cycle run by cruise control
model CruiseControlPollLog {
  id               Int       @id @default(autoincrement())
  pollStartedAt    DateTime
  pollCompletedAt  DateTime?
  durationMs       Int?
  positionsChecked Int       @default(0)
  stopsRatcheted   Int       @default(0)
  stopsUnchanged   Int       @default(0)
  retryFailures    Int       @default(0)
  t212Unavailable  Boolean   @default(false)
  error            String?
  createdAt        DateTime  @default(now())

  @@index([pollStartedAt])
}
