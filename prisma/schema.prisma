// VolumeTurtle — Prisma Schema (independent from HybridTurtle)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A ticker in the scan universe
model Ticker {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String?
  sector    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes  DailyQuote[]

  @@index([symbol])
}

/// OHLCV daily bar from Yahoo Finance
model DailyQuote {
  id        Int      @id @default(autoincrement())
  tickerId  Int
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  adjClose  Float
  volume    BigInt

  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, date])
  @@index([date])
}

/// Nightly scan run metadata
model ScanRun {
  id          Int      @id @default(autoincrement())
  startedAt   DateTime @default(now())
  completedAt DateTime?
  tickersScanned Int   @default(0)
  signalsFound   Int   @default(0)
  status      String   @default("RUNNING") // RUNNING | COMPLETED | FAILED
  error       String?
  trigger     String   @default("MANUAL") // MANUAL | SCHEDULED
  market      String   @default("ALL")    // ALL | LSE | US | EU
  durationMs  Int?                        // scan duration in milliseconds
  marketRegime String?                    // BULLISH | BEARISH
  vixLevel     Float?                     // VIX close value
  qqqVs200MA   Float?                     // % above/below 200MA
}

/// A trade opened (and possibly closed) by VolumeTurtle
model Trade {
  id            String    @id @default(cuid())
  ticker        String
  entryDate     DateTime
  entryPrice    Float
  shares        Float
  hardStop      Float
  trailingStop  Float
  exitDate      DateTime?
  exitPrice     Float?
  exitReason    String?   // ExitReason: "HARD_STOP" | "TRAILING_STOP" | "MANUAL" | "T212_STOP"
  rMultiple     Float?    // (exitPrice - entryPrice) / riskPerShare
  status        String    // "OPEN" | "CLOSED"
  volumeRatio   Float     // volume spike ratio at entry
  rangePosition Float     // price range position at entry
  atr20         Float     // ATR at entry
  importedFromT212  Boolean   @default(false)
  importedAt        DateTime?
  manualEntry       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stopHistory   StopHistory[]

  @@index([ticker])
  @@index([status])
}

/// Stop level history for a trade
model StopHistory {
  id            String    @id @default(cuid())
  tradeId       String
  trade         Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  date          DateTime
  stopLevel     Float
  stopType      String    // "HARD" | "TRAILING"
  changed       Boolean   // true if stop moved up vs previous day
  changeAmount  Float?    // positive number, only set if changed = true
  actioned      Boolean   @default(false)
  actionedAt    DateTime?
  note          String?   // optional note explaining stop change
  createdAt     DateTime  @default(now())

  @@index([tradeId])
}

/// Result of a nightly scan for a single ticker
model ScanResult {
  id            String   @id @default(cuid())
  scanDate      DateTime
  ticker        String
  signalFired   Boolean
  volumeRatio   Float?
  rangePosition Float?
  atr20          Float?
  compositeScore Float?   // 0.00–1.00 composite signal quality
  compositeGrade String?  // "A" | "B" | "C" | "D"
  actionTaken    String?  // "ENTERED" | "SIGNAL_FIRED" | "SKIPPED_MAX_POSITIONS" | "SKIPPED_EQUITY_PAUSE" | "NO_SIGNAL"
  // Signal detail (populated only when signalFired = true)
  suggestedEntry Float?
  hardStop        Float?
  riskPerShare    Float?
  shares          Float?
  totalExposure   Float?
  dollarRisk      Float?
  // Composite sub-scores
  regimeScore     Float?
  trendScore      Float?
  volumeCompScore Float?  // named to avoid clash with volumeRatio
  liquidityScore  Float?
  createdAt      DateTime @default(now())

  @@unique([ticker, scanDate])
  @@index([scanDate])
  @@index([ticker])
}

/// Daily account balance snapshot
model AccountSnapshot {
  id         String   @id @default(cuid())
  date       DateTime
  balance    Float
  openTrades Int
  createdAt  DateTime @default(now())

  @@index([date])
}

/// Key-value settings store
model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

/// Trading 212 connection configuration
model T212Connection {
  id              String    @id @default(cuid())
  environment     String    // "demo" | "live"
  apiKey          String    // env var reference e.g. "ENV:T212_API_KEY"
  accountType     String    // "invest" | "isa" | "both"
  connected       Boolean   @default(false)
  lastSyncAt      DateTime?
  lastSyncStatus  String?   // "success" | "error"
  lastSyncError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
