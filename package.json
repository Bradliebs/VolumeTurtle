{
  "name": "tradecore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "test": "jest",
    "test:fta": "jest --testPathPatterns=timing-scorer --verbose",
    "test:watch": "jest --watch",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "scan": "npx tsx scripts/nightlyScan.ts",
    "scan:dry": "npx tsx scripts/nightlyScan.ts --dry-run",
    "validate": "npx tsx scripts/validateUniverse.ts",
    "validate:universe": "npx tsx scripts/validateUniverse.ts",
    "universe:health": "npx tsx scripts/universeHealth.ts",
    "repair:false-closes": "npx tsx scripts/repairFalseClosedTrades.ts",
    "repair:false-closes:apply": "npx tsx scripts/repairFalseClosedTrades.ts --apply",
    "schedule:setup": "scripts\\setupScheduler.bat",
    "schedule:remove": "schtasks /delete /tn VolumeTurtle_LSE_Scan /f && schtasks /delete /tn VolumeTurtle_US_Scan /f && schtasks /delete /tn VolumeTurtle_Startup /f",
    "schedule:status": "schtasks /query /tn VolumeTurtle_LSE_Scan && schtasks /query /tn VolumeTurtle_US_Scan",
    "backup": "npx tsx scripts/backup.ts",
    "restore": "npx tsx scripts/restore.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "next": "14.2.35",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "yahoo-finance2": "^3.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jest": "^30.3.0",
    "postcss": "^8",
    "prisma": "^7.5.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
