{
  "name": "tradecore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "test": "jest",
    "test:fta": "jest --testPathPatterns=timing-scorer --verbose",
    "test:watch": "jest --watch",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "scan": "npx tsx scripts/nightlyScan.ts",
    "scan:dry": "npx tsx scripts/nightlyScan.ts --dry-run",
    "validate": "npx tsx scripts/validateUniverse.ts",
    "validate:universe": "npx tsx scripts/validateUniverse.ts",
    "universe:health": "npx tsx scripts/universeHealth.ts",
    "repair:false-closes": "npx tsx scripts/repairFalseClosedTrades.ts",
    "repair:false-closes:apply": "npx tsx scripts/repairFalseClosedTrades.ts --apply",
    "schedule:setup": "scripts\\setupScheduler.bat",
    "schedule:remove": "schtasks /delete /tn VolumeTurtle_Scan_LSE /f & schtasks /delete /tn VolumeTurtle_Scan_US /f & schtasks /delete /tn VolumeTurtle_CruiseControl /f & schtasks /delete /tn VolumeTurtle_ExecutionScheduler /f & schtasks /delete /tn VolumeTurtle_UniverseSnapshot /f & schtasks /delete /tn VolumeTurtle_AutoTune /f",
    "schedule:status": "schtasks /query /tn VolumeTurtle_Scan_LSE & schtasks /query /tn VolumeTurtle_Scan_US & schtasks /query /tn VolumeTurtle_CruiseControl & schtasks /query /tn VolumeTurtle_ExecutionScheduler & schtasks /query /tn VolumeTurtle_UniverseSnapshot & schtasks /query /tn VolumeTurtle_AutoTune",
    "verify:execution": "npx tsx scripts/verifyExecution.ts",
    "seed:cache": "npx tsx scripts/seedCache.ts",
    "enrich:sectors": "npx tsx scripts/enrichSectors.ts",
    "backup": "npx tsx scripts/backup.ts",
    "restore": "npx tsx scripts/restore.ts",
    "backtest": "npx tsx scripts/backtest.ts",
    "backtest:analyze": "npx tsx scripts/analyzeBacktest.ts",
    "backtest:sweep": "npx tsx scripts/sweepBacktest.ts",
    "backtest:sweep:quick": "npx tsx scripts/sweepBacktest.ts --quick",
    "tune": "npx tsx scripts/autoTune.ts",
    "tune:quick": "npx tsx scripts/autoTune.ts --quick",
    "tune:notify": "npx tsx scripts/autoTune.ts --notify",
    "walkforward": "npx tsx scripts/walkForward.ts",
    "walkforward:quick": "npx tsx scripts/walkForward.ts --quick",
    "snapshot:universe": "npx tsx scripts/snapshotUniverse.ts",
    "backfill:quotes": "npx tsx scripts/backfillQuotes.ts",
    "divergence": "npx tsx scripts/divergenceTracker.ts",
    "watchdog:independent": "npx tsx scripts/watchdogIndependent.ts",
    "agent": "npx tsx src/agent/runner.ts",
    "agent:sunday": "npx tsx src/agent/runner-sunday.ts",
    "agent:friday": "npx tsx src/agent/runner-friday.ts",
    "agent:listen": "npx tsx src/agent/telegram-listener.ts",
    "agent:curate": "npx tsx src/agent/runner-sunday.ts",
    "schedule:agent:setup": "npx tsx scripts/schedule-agent.ts setup",
    "schedule:agent:remove": "npx tsx scripts/schedule-agent.ts remove",
    "schedule:agent:status": "npx tsx scripts/schedule-agent.ts status"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "next": "14.2.35",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "yahoo-finance2": "^3.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jest": "^30.3.0",
    "postcss": "^8",
    "prisma": "^7.5.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
